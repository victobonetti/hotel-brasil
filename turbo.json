{
	"$schema": "https://turborepo.com/schema.json",
	"globalEnv": ["DATABASE_URL", "AUTH_SECRET", "PORT"],
	"globalPassThroughEnv": [
		"NODE_ENV",
		"CI",
		"VERCEL",
		"VERCEL_ENV",
		"VERCEL_URL",
		"npm_lifecycle_event"
	],
	"tasks": {
		"//#check": {
			"cache": false
		},
		"//#clean": {
			"cache": false
		},
		"//#format": {
			"cache": false
		},
		"build": {
			"dependsOn": ["^build"],
			"outputs": [".cache/tsbuildinfo.json", "dist/**"]
		},
		"clean": {
			"cache": false
		},
		"dev": {
			"cache": false,
			"persistent": false
		},
		"push": {
			"cache": false,
			"interactive": true
		},
		"studio": {
			"cache": false,
			"persistent": true
		},
		"topo": {
			"dependsOn": ["^topo"]
		},
		"tsc": {
			"dependsOn": ["^topo", "typegen"],
			"outputs": [".cache/tsbuildinfo.json"]
		},
		"typegen": {
			"outputs": ["next-env.d.ts", ".next/types/**"]
		},
		"ui-add": {
			"cache": false,
			"interactive": true
		}
	},
	"ui": "tui"
}
