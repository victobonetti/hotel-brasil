{
	"dependencies": {
		"@nowait24/db": "workspace:*",
		"@nowait24/utils": "workspace:*",
		"better-auth": "catalog:"
	},
	"devDependencies": {
		"@better-auth/cli": "catalog:",
		"@nowait24/tsconfig": "workspace:*",
		"dotenv-cli": "catalog:",
		"typescript": "catalog:"
	},
	"exports": {
		".": "./src/index.ts",
		"./client": "./src/client.ts"
	},
	"name": "@nowait24/auth",
	"private": true,

	"scripts": {
		"clean": "git clean -xdf .cache .turbo dist node_modules",
		"generate": "dotenv -e ../../apps/nextjs/.env -- pnpx @better-auth/cli generate --config script/auth-cli.ts --output ../db/src/auth-schema.ts",
		"tsc": "tsc --noEmit"
	},
	"type": "module"
}
