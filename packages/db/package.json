{
	"dependencies": {
		"drizzle-orm": "catalog:",
		"drizzle-zod": "catalog:",
		"postgres": "^3.4.7",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@finchat/tsconfig": "workspace:*",
		"@types/node": "catalog:",
		"dotenv-cli": "catalog:",
		"drizzle-kit": "catalog:",
		"typescript": "catalog:"
	},
	"exports": {
		"./client": "./src/client.ts",
		"./schema": "./src/schema.ts"
	},
	"name": "@finchat/db",
	"private": true,
	"scripts": {
		"build": "tsc",
		"clean": "git clean -xdf .cache .turbo dist node_modules",
		"dev": "trap 'docker compose stop' EXIT; docker compose up --build",
		"push": "bun wait-for-db && bun with-env drizzle-kit push",
		"studio": "bun wait-for-db && bun with-env drizzle-kit studio",
		"tsc": "tsc --noEmit --emitDeclarationOnly false",
		"wait-for-db": "while ! nc -z localhost 5432; do sleep 1; done",
		"with-env": "dotenv -e ../../apps/nextjs/.env --"
	},
	"type": "module"
}
