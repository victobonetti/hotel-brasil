# Shared app environment

# Postgres connection string used by Drizzle and the Next.js app.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nowait24"

# Google OAuth credentials for better-auth.
AUTH_GOOGLE_CLIENT_ID="your-google-client-id"
AUTH_GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Auth secret.
# Required in production and recommended locally to keep auth behavior consistent.
AUTH_SECRET="replace-with-a-long-random-secret"

# OCI Object Storage via S3-compatible API.
STORAGE_BUCKET="nowait24-menu-images"
STORAGE_REGION="sa-saopaulo-1"
STORAGE_ENDPOINT="https://<namespace>.compat.objectstorage.sa-saopaulo-1.oraclecloud.com"
STORAGE_ACCESS_KEY_ID="your-oci-customer-access-key"
STORAGE_SECRET_ACCESS_KEY="your-oci-customer-secret-key"
STORAGE_PUBLIC_BASE_URL="https://<public-host-or-bucket-base-url>"
STORAGE_FORCE_PATH_STYLE="true"
STORAGE_MENU_ITEMS_PREFIX="menu-items"

# Optional local overrides.
NODE_ENV="development"
PORT="3000"
