{
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"@turbo/gen": "catalog:",
		"baseline-browser-mapping": "^2.10.19",
		"dotenv-cli": "catalog:",
		"turbo": "catalog:",
		"typescript": "catalog:"
	},
	"engines": {
		"bun": "^1.3.5",
		"node": "^22.21.0"
	},
	"name": "create-t3-turbo",
	"packageManager": "bun@1.3.5",
	"private": true,
	"scripts": {
		"auth:generate": "bun run -F @nowait24/auth generate",
		"build": "turbo run build",
		"check": "biome check .",
		"clean": "git clean -xdf node_modules",
		"clean:workspaces": "turbo run clean",
		"db:push": "turbo -F @nowait24/db dev push",
		"dev": "turbo dev studio --continue -F @nowait24/nextjs...",
		"format": "biome check . --write --unsafe --error-on-warnings",
		"pull-secrets": "bun -F './apps/*' pull-secrets",
		"test": "turbo run test",
		"tsc": "turbo run tsc",
		"ui-add": "turbo run ui-add"
	},
	"workspaces": {
		"catalog": {
			"@base-ui/react": "1.0.0",
			"@better-auth/cli": "1.4.0-beta.9",
			"@biomejs/biome": "2.3.10",
			"@neondatabase/serverless": "1.0.1",
			"@radix-ui/react-icons": "1.3.2",
			"@t3-oss/env-core": "0.13.8",
			"@t3-oss/env-nextjs": "0.13.8",
			"@tailwindcss/postcss": "4.1.16",
			"@tailwindcss/vite": "4.1.16",
			"@tanstack/react-form": "1.23.8",
			"@tanstack/react-query": "5.90.8",
			"@trpc/client": "11.7.1",
			"@trpc/server": "11.7.1",
			"@trpc/tanstack-react-query": "11.7.1",
			"@turbo/gen": "2.5.8",
			"@types/node": "22.18.12",
			"@types/react": "19.1.0",
			"@types/react-dom": "19.1.0",
			"@vitejs/plugin-react": "5.1.0",
			"better-auth": "1.4.0-beta.9",
			"class-variance-authority": "0.7.1",
			"clsx": "2.1.1",
			"dotenv-cli": "10.0.0",
			"drizzle-kit": "0.31.5",
			"drizzle-orm": "0.44.7",
			"drizzle-zod": "0.8.3",
			"jiti": "2.5.1",
			"next": "16.0.9",
			"next-themes": "0.4.6",
			"postcss": "8.5.6",
			"radix-ui": "1.4.3",
			"react": "19.1.4",
			"react-dom": "19.1.4",
			"server-only": "0.0.1",
			"sonner": "2.0.7",
			"superjson": "2.2.3",
			"tailwind-merge": "3.3.1",
			"tailwindcss": "4.1.16",
			"turbo": "2.7.2",
			"tw-animate-css": "1.4.0",
			"typescript": "5.9.3",
			"vite": "7.1.12",
			"zod": "4.1.12"
		},
		"packages": [
			"apps/*",
			"packages/*",
			"tooling/*"
		]
	}
}
