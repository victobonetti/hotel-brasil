{
  "name": "create-t3-turbo",
  "private": true,
  "engines": {
    "node": "^22.21.0",
    "bun": "^1.3.5"
  },
  "packageManager": "bun@1.3.5",
  "scripts": {
    "build": "turbo run build",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo run clean",
    "auth:generate": "bun -F @finchat/auth generate",
    "db:push": "turbo -F @finchat/db push",
    "db:studio": "turbo -F @finchat/db studio",
    "dev:next": "turbo watch dev -F @finchat/nextjs...",
    "lint:ws": "bunx sherif@latest",
    "typecheck": "turbo run typecheck",
    "ui-add": "turbo run ui-add"
  },
  "devDependencies": {
    "@turbo/gen": "catalog:",
    "dotenv-cli": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  },
  "workspaces": {
    "packages": ["apps/*", "packages/*", "tooling/*"],
    "catalog": {
      "@better-auth/cli": "1.4.0-beta.9",
      "@radix-ui/react-icons": "1.3.2",
      "@tailwindcss/postcss": "4.1.16",
      "@tailwindcss/vite": "4.1.16",
      "@t3-oss/env-core": "0.13.8",
      "@t3-oss/env-nextjs": "0.13.8",
      "@tanstack/react-form": "1.23.8",
      "@tanstack/react-query": "5.90.8",
      "@trpc/client": "11.7.1",
      "@trpc/server": "11.7.1",
      "@trpc/tanstack-react-query": "11.7.1",
      "@turbo/gen": "2.5.8",
      "@types/node": "22.18.12",
      "@types/react": "19.1.0",
      "@types/react-dom": "19.1.0",
      "@vercel/postgres": "0.10.0",
      "@vitejs/plugin-react": "5.1.0",
      "better-auth": "1.4.0-beta.9",
      "class-variance-authority": "0.7.1",
      "dotenv-cli": "10.0.0",
      "drizzle-kit": "0.31.5",
      "drizzle-orm": "0.44.7",
      "drizzle-zod": "0.8.3",
      "jiti": "2.5.1",
      "next": "16.0.9",
      "postcss": "8.5.6",
      "radix-ui": "1.4.3",
      "react": "19.1.4",
      "react-dom": "19.1.4",
      "sonner": "2.0.7",
      "superjson": "2.2.3",
      "tailwind-merge": "3.3.1",
      "tailwindcss": "4.1.16",
      "tw-animate-css": "1.4.0",
      "turbo": "2.5.8",
      "typescript": "5.9.3",
      "zod": "4.1.12",
      "vite": "7.1.12"
    }
  }
}
